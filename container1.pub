ssh-rsa  zqp@zqp
docker cp container1.pub tailscale-container-2:/root/.ssh/
docker exec -it tailscale-container-2 bash -c "cat /root/.ssh/container1.pub >> /root/.ssh/authorized_keys"

# 方法2：直接复制容器2的公钥到容器1的authorized_keys
docker exec -it tailscale-container-2 cat /root/.ssh/id_rsa.pub > container2.pub
docker cp container2.pub tailscale-container-1:/root/.ssh/
docker exec -it tailscale-container-1 bash -c "cat /root/.ssh/container2.pub >> /root/.ssh/authorized_keys"

# 设置权限
docker exec -it tailscale-container-1 chmod 600 /root/.ssh/authorized_keys
docker exec -it tailscale-container-2 chmod 600 /root/.ssh/authorized_keys

# 测试连接
docker exec -it tailscale-container-1 ssh -o StrictHostKeyChecking=no root@100.100.242.28 echo "SSH连接测试成功！"

# 清理临时文件
rm -f container1.pub container2.pub
